00006D92                          4050  TILE5       ; VELOCITY UPDATE TILE
00006D92  2F01                    4051              MOVE.L D1,-(A7)
00006D94  223C 0000FFFF           4052              MOVE.L #$0000FFFF,D1
00006D9A  4EB9 00006DA4           4053              JSR DRAWTILE
00006DA0  221F                    4054              MOVE.L (A7)+,D1
