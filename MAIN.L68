00006E66  0679 0020 000073B8      4179  .DONE       ADD.W #TILESIZE,(DRAWX)
00006E6E  51C8 FFDE               4180              DBRA D0,.DRAWROW
00006E72                          4181              ; GO TO NEXT ROW
00006E72  33FC 0000 000073B8      4182              MOVE.W #0,(DRAWX)
00006E7A  0679 0020 000073BA      4183              ADD.W #TILESIZE,(DRAWY)
00006E82  51C9 FFC6               4184              DBRA D1,.NEXTROW
00006E86                          4185              
00006E86  4CDF 0307               4186              MOVEM.L (A7)+,D0-D2/A0-A1
00006E8A                          4187  
00006E8A  4E75                    4188              RTS
