00002744                           598  ; ==============================================================================
00002744                           599  ; ENEMY DATA
00002744                           600  ; ==============================================================================
00002744                           601  ; ENMDATA STORES, FOR EACH ENEMY IN THE MAP:
00002744                           602  ; - A WORD STATING SCREEN X (LOW BYTE) AND Y (HIGH BYTE) WHERE IS THE ENEMY.
00002744                           603  ; - THE DATA TO PASS TO D1 AND D2 IN ENMINIT:
00002744                           604  ;   - D1.L HIGH WORD INITIAL Y. LOW WORD INITIAL X
00002744                           605  ;   - D2.W HIGH BYTE ENEMY TYPE. LOW BYTE ENEMY INITIAL DIRECTION
00002744                           606  ; A WORD FFFF IS USED AS TERMINATOR.
00002744                           607  ; -----------------------------------------------------------------------------
00002744                           608  
00002744= 0000                     609  ENMDATA     DC.W    $0000
00002746= 01A0                     610              DC.W    TILESIZE*13
00002748= 01D0                     611              DC.W    TILESIZE*14+TILESIZE/2
0000274A= 0001                     612              DC.W    $0001
0000274C                           613  
0000274C= 0001                     614              DC.W    $0001
0000274E= 0060                     615              DC.W    TILESIZE*3
00002750= 01B0                     616              DC.W    TILESIZE*13+TILESIZE/2
00002752= 0000                     617              DC.W    $0000
00002754                           618              
