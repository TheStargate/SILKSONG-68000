0000283C  2008                     815              MOVE.L  A0,D0
0000283E  C0BC FFFFFFC0            816              AND.L   #-DMMBSIZE,D0           ; TAKE ADVANTAGE OF ALIGNMENT
00002844  0680 00000040            817              ADD.L   #DMMBSIZE,D0
0000284A  2040                     818              MOVE.L  D0,A0
0000284C  201F                     819              MOVE.L  (A7)+,D0
