0000280C  0680 00000040            783              ADD.L   #DMMBSIZE,D0
00002812  2040                     784              MOVE.L  D0,A0
00002814  201F                     785              MOVE.L  (A7)+,D0
00002816  60DA                     786              BRA     DMMFRCOM
00002818                           787  
00002818                           788  ; -----------------------------------------------------------------------------
00002818                           789  DMMFRSTO
00002818                           790  ; SEARCHES THE FIRST MEMORY SLOT WITH THE SPECIFIED ID AND OUTPUTS A POINTER
00002818                           791  ; TO THE CORRESPONDING DATA (SLOT ADDRESS+2)
00002818                           792  ; INPUT    - D0.W : ID TO SEARCH
00002818                           793  ; OUTPUT   - A0   : POINTER TO THE DATA OR 0 IF NOT FOUND
