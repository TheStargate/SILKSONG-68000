00002C00                          1307  ; ------------------------------------------------------------------------------
00002C00                          1308  PRJINIT
00002C00                          1309  ; INITIALIZE PROJECTILE.
00002C00                          1310  ; INPUT    : A0 POINTER TO THE INSTANCE VARIABLES 
00002C00                          1311  ;            D0 IF 0 PROJECTILE IS FROM PLAYER, IF NOT ENMPOSX
00002C00                          1312  ;            D1 ENMPOSY (OR NOTHING)
00002C00                          1313  ;            D2 ENMDIR (OR NOTHING)
00002C00                          1314  ; OUTPUT   : NONE
00002C00                          1315  ; MODIFIES : NONE
00002C00                          1316  ; ------------------------------------------------------------------------------
