00006E2E                          4153               
00006E2E                          4154              ; GET CURRENT SCREEN
00006E2E  2039 000073B4           4155              MOVE.L  (MAPSCR),D0
00006E34  3040                    4156              MOVEA   D0,A0
00006E36                          4157                          
00006E36  33FC 0000 000073B8      4158              MOVE.W #0,(DRAWX)
00006E3E  33FC 0000 000073BA      4159              MOVE.W #0,(DRAWY)
00006E46                          4160              
00006E46                          4161              ; PLOT EVERY TILE OF THE CURRENT SCREEN
00006E46  323C 000E               4162              MOVE.W #MAPSCRH-1,D1
00006E4A                          4163  .NEXTROW
00006E4A  303C 0013               4164              MOVE.W #MAPSCRW-1,D0
00006E4E                          4165  .DRAWROW
00006E4E  1418                    4166              MOVE.B (A0)+,D2                 ; GET TILE ID
00006E50  6700 0014               4167              BEQ   .DONE                     ; SKIP IF D2 = 0 (EMPTY TILE)
00006E54                          4168              ; ADAPT THE ID TO THE TILE PLOT VECTOR
00006E54  C47C 00FF               4169              AND.W #$00FF,D2
00006E58  E542                    4170              ASL.W #2,D2
00006E5A  5942                    4171              SUBQ.W  #4,D2
00006E5C                          4172              
