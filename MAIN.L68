00006D20                          3987  GETTILE
00006D20                          3988  ; GET A TILE ID BASED ON THE GIVEN COORDS (IN PIXELS)
00006D20                          3989  ; INPUT    : D0 - X COORD (IN PIXELS) OF THE DESIRED TILE
00006D20                          3990  ;            D1 - Y COORD (IN PIXELS) OF THE DESIRED TILE
00006D20                          3991  ;            A0 - MAP ADDRESS
00006D20                          3992  ; OUTPUT   : D0 - TILE ID
00006D20                          3993  ; MODIFIES : D0 AND D1 (TO CALCULATE THE TILE POSITION)
00006D20                          3994  ; ------------------------------------------------------------------------------
00006D20  2F09                    3995              MOVE.L A1,-(A7)
00006D22                          3996              
00006D22  2248                    3997              MOVEA.L A0,A1
00006D24                          3998              
00006D24                          3999              ; GET TILE POSITION X
00006D24                          4000              ; DIVIDE BY 32 (TILESIZE)
00006D24  EA48                    4001              LSR.W   #5, D0            
00006D26  D2C0                    4002              ADD.W   D0,A1
00006D28                          4003              
00006D28                          4004              ; GET TILE POSITION Y
00006D28                          4005              ; DIVIDE BY 32/20 (TILESIZE/MAPSCRW)
00006D28  EA49                    4006              LSR.W   #5, D1
00006D2A  C2FC 0014               4007              MULU    #MAPSCRW, D1  
00006D2E  D2C1                    4008              ADD.W   D1,A1
00006D30                          4009             
00006D30                          4010              ; GET TILE ID
00006D30  1011                    4011              MOVE.B  (A1),D0
00006D32                          4012              
00006D32  225F                    4013              MOVE.L (A7)+,A1
00006D34  4E75                    4014              RTS       
00006D36                          4015  
00006D36                          4016  ; ------------------------------------------------------------------------------
