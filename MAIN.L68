00006DFA                          4125  ; INPUT    : NONE 
00006DFA                          4126  ; OUTPUT   : NONE
00006DFA                          4127  ; MODIFIES : NONE
00006DFA                          4128  ; ------------------------------------------------------------------------------
00006DFA  48E7 8080               4129              MOVEM.L D0/A0,-(A7)
00006DFE  C0BC 000000FF           4130              AND.L   #$000000FF,D0
00006E04                          4131              ; GET CURRENT SCREEN FROM MAP VECTOR
00006E04  41F8 1000               4132              LEA MAPVEC,A0
00006E08                          4133              ; GET X SCREEN
00006E08  1039 000073B0           4134              MOVE.B  (MAPPOSX),D0
00006E0E  E500                    4135              ASL.B   #2,D0
00006E10  D1C0                    4136              ADD.L   D0,A0
00006E12                          4137              ; GET Y SCREEN (8 SCREENS FOR ROW. MULTIPLY MAPPOSY BY 8)
00006E12  1039 000073B1           4138              MOVE.B  (MAPPOSY),D0
00006E18  EB00                    4139              ASL.B   #5,D0
00006E1A  D1C0                    4140              ADD.L   D0,A0
00006E1C  2010                    4141              MOVE.L  (A0),D0
00006E1E  23C0 000073B4           4142              MOVE.L  D0,(MAPSCR)
00006E24  4CDF 0101               4143              MOVEM.L (A7)+,D0/A0            
00006E28  4E75                    4144              RTS
