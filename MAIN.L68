000027BE                           713              INCLUDE "LIB/DMMCONST.X68"
000027BE                           714  ; =============================================================================
000027BE                           715  ; DYNAMIC MEMORY MANAGEMENT CONSTANTS (SYSTEM CONSTANTS)
000027BE                           716  ; =============================================================================
000027BE                           717  
000027BE  =00000040                718  DMMBSIZE    EQU     64                      ; BLOCK SIZE (BYTES). POWER OF TWO
000027BE  =00000032                719  DMMBNUM     EQU     50                      ; NUMBER OF BLOCKS
000027BE  =00000000                720  DMMSYSID    EQU     0                       ; SYSTEM OWNER ID (MUST BE 0)
000027BE  =00000000                721  -------------------- end include --------------------
000027BE                           722              INCLUDE "LIB/UTLCONST.X68"
000027BE                           723  ; ==============================================================================
000027BE                           724  ; UTIL CONSTANTS
000027BE                           725  ; ==============================================================================
000027BE                           726  
000027BE  =00000008                727  UTLCHRWD    EQU     8                       ; CHARACTER WIDTH IN PIXELS
000027BE  =00000008                728  -------------------- end include --------------------
000027BE                           729              INCLUDE "LIB/DMMCODE.X68"
000027BE                           730  ; =============================================================================
000027BE                           731  ; DYNAMIC MEMORY MANAGEMENT (SYSTEM CODE)
000027BE                           732  ; DYNAMIC MEMORY IS A SET OF DMMBNUM SLOTS OF DMMBSIZE BYTES EACH ONE.
000027BE                           733  ; DMMBSIZE MUST BE POWER OF TWO. A SLOT HAS:
000027BE                           734  ; - HEADER - 1 WORD. SPECIFIES THE OWNER (0 MEANS OWNED BY SYSTEM)
000027BE                           735  ; - DATA   - DMMBSIZE - 2 BYTES. MAY CONTAIN VARS AND ANY KIND OF DATA RELATED
000027BE                           736  ;            THE THE OWNER. IF OWNER==0, DATA IS MEANINGLESS.
000027BE                           737  ; =============================================================================
000027BE                           738  
000027BE                           739  ; -----------------------------------------------------------------------------
000027BE                           740  DMMINIT
000027BE                           741  ; INITIALIZES THE DYNAMIC MEMORY TO ALL OWNED BY SYSTEM.
000027BE                           742  ; INPUT    - NONE
000027BE                           743  ; OUTPUT   - NONE
000027BE                           744  ; MODIFIES - NONE
000027BE                           745  ; -----------------------------------------------------------------------------
000027BE  48E7 8080                746              MOVEM.L D0/A0,-(A7)
000027C2  41F9 00007400            747              LEA     DMMDATA,A0
000027C8  303C 0031                748              MOVE.W  #DMMBNUM-1,D0
000027CC  30BC 0000                749  .LOOP       MOVE.W  #DMMSYSID,(A0)
000027D0  D1FC 00000040            750              ADD.L   #DMMBSIZE,A0
