00002A36                          1117              INCLUDE "LIB/AGLCODE.X68"
00002A36                          1118  ; =============================================================================
00002A36                          1119  ; AGENT MANAGEMENT
00002A36                          1120  ; EACH AGENT HAS A DATA BLOCK FROM DMM AS FOLLOWS:
00002A36                          1121  ; +0 - LONG : UPDATE SUBROUTINE POINTER
00002A36                          1122  ; +4 - LONG : PLOT SUBROUTINE POINTER
00002A36                          1123  ; +8:END    : DATA (AGENT SPECIFIC)
00002A36                          1124  ; =============================================================================
00002A36                          1125  
00002A36                          1126  ; -----------------------------------------------------------------------------
00002A36                          1127  AGLADD
00002A36                          1128  ; CREATES A NEW AGENT
00002A36                          1129  ; INPUT    - A1 - POINTER TO AGENT INIT FUNCTION
00002A36                          1130  ;            A2 - POINTER TO AGENT UPDATE FUNCTION
00002A36                          1131  ;            A3 - POINTER TO AGENT PLOT FUNCTION
00002A36                          1132  ;            D0 - AGENT TYPE (USED AS OWNER BY DMM)
00002A36                          1133  ;            D1 - AGENT INITIALIZATION PARAMETER 1
00002A36                          1134  ;            D2 - AGENT INITIALIZATION PARAMETER 2
00002A36                          1135  ;            D3 - AGENT INITIALIZATION PARAMETER 3
00002A36                          1136  ; OUTPUT   - NONE
00002A36                          1137  ; MODIFIES - NONE
00002A36                          1138  ; -----------------------------------------------------------------------------
00002A36  2F08                    1139              MOVE.L  A0,-(A7)
00002A38  4EB8 2850               1140              JSR     DMMALLOC
00002A3C  B1FC 00000000           1141              CMP.L   #0,A0
00002A42  6700 0008               1142              BEQ     .END
00002A46  20CA                    1143              MOVE.L  A2,(A0)+
00002A48  20CB                    1144              MOVE.L  A3,(A0)+
00002A4A  4E91                    1145              JSR     (A1)
00002A4C  205F                    1146  .END        MOVE.L  (A7)+,A0
00002A4E  4E75                    1147              RTS
00002A50                          1148  
00002A50                          1149  ; -----------------------------------------------------------------------------
00002A50                          1150  AGLUPD
00002A50                          1151  ; UPDATES THE AGENT LIST. PRIOR TO CALLING THE UPDATE FUNCTIONS, A0 IS SET
00002A50                          1152  ; TO THE DATA BLOCK OF THE CORRESPONDING SLOT.
00002A50                          1153  ; INPUT    - NONE
00002A50                          1154  ; OUTPUT   - NONE
00002A50                          1155  ; MODIFIES - NONE
00002A50                          1156  ; -----------------------------------------------------------------------------
00002A50  48E7 00C0               1157              MOVEM.L A0-A1,-(A7)
00002A54  4EB8 27E0               1158              JSR     DMMFIRST
00002A58  B1FC 00000000           1159  .LOOP       CMP.L   #0,A0
00002A5E  6700 000E               1160              BEQ     .END
00002A62  2250                    1161              MOVE.L  (A0),A1
00002A64  5088                    1162              ADD.L   #8,A0
00002A66  4E91                    1163              JSR     (A1)
00002A68  4EB8 2802               1164              JSR     DMMNEXT
