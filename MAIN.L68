0000282A  B1FC 0000807F            800  DMMFCOM     CMP.L   #DMMDATA+DMMBSIZE*DMMBNUM-1,A0
00002830  6DEC                     801              BLT     DMMFLOOP
00002832  207C 00000000            802              MOVE.L  #0,A0
00002838  4E75                     803  DMMFFND     RTS
0000283A                           804  
0000283A                           805  ; -----------------------------------------------------------------------------
0000283A                           806  DMMNEXTO
0000283A                           807  ; SEARCHES THE NEXT MEMORY SLOT WITH THE SPECIFIED ID AND OUTPUTS A POINTER
0000283A                           808  ; TO THE CORRESPONDING DATA (SLOT ADDRESS+2)
0000283A                           809  ; INPUT    - D0.W : ID TO SEARCH
0000283A                           810  ;            A0   : POINTER WITHIN THE CURRENT SLOT
0000283A                           811  ; OUTPUT   - A0   : POINTER TO THE DATA OR 0 IF NOT FOUND
0000283A                           812  ; MODIFIES - NONE (ASIDE OF OUTPUT)
