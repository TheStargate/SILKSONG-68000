00002860  6700 0006                835              BEQ     .END
00002864  3140 FFFE                836              MOVE.W  D0,-2(A0)
00002868  4E75                     837  .END        RTS
0000286A                           838  
0000286A                           839  ; -----------------------------------------------------------------------------
