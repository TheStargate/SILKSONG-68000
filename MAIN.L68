000027E0                           755  ; -----------------------------------------------------------------------------
000027E0                           756  DMMFIRST
000027E0                           757  ; SEARCHES THE FIRST MEMORY SLOT NOT OWNED BY SYSTEM AND OUTPUTS A POINTER
000027E0                           758  ; TO THE CORRESPONDING DATA (SLOT ADDRESS+2)
000027E0                           759  ; INPUT    - NONE
000027E0                           760  ; OUTPUT   - A0   : POINTER TO THE DATA OR 0 IF NOT FOUND
000027E0                           761  ; MODIFIES - NONE (ASIDE OF OUTPUT)
000027E0                           762  ; -----------------------------------------------------------------------------
000027E0  41F9 00007400            763              LEA     DMMDATA,A0
000027E6  4A58                     764  DMMFRLOP    TST.W   (A0)+
000027E8  6600 0016                765              BNE     DMMFRFND
000027EC  D1FC 0000003E            766              ADD.L   #DMMBSIZE-2,A0
000027F2  B1FC 0000807F            767  DMMFRCOM    CMP.L   #DMMDATA+DMMBSIZE*DMMBNUM-1,A0
000027F8  6DEC                     768              BLT     DMMFRLOP
000027FA  207C 00000000            769              MOVE.L  #0,A0
00002800  4E75                     770  DMMFRFND    RTS
00002802                           771  
00002802                           772  ; -----------------------------------------------------------------------------
00002802                           773  DMMNEXT
00002802                           774  ; SEARCHES THE NEXT MEMORY SLOT NOT OWNED BY SYSTEM AND OUTPUTS A POINTER
00002802                           775  ; TO THE CORRESPONDING DATA (SLOT ADDRESS+2)
00002802                           776  ; INPUT    - A0   : POINTER WITHIN THE CURRENT SLOT
00002802                           777  ; OUTPUT   - A0   : POINTER TO THE DATA OR 0 IF NOT FOUND
00002802                           778  ; MODIFIES - NONE (ASIDE OF OUTPUT)
